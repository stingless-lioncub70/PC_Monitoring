{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "PC Monitor",
  "version": "0.1.0",
  "identifier": "dev.allain-afk.pc-monitor",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "PC Monitor",
        "width": 1100,
        "height": 720,
        "minWidth": 880,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "dev-allain-afk",
    "copyright": "Copyright (c) 2026 dev-allain-afk",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/monitor",
      "binaries/sensors"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
