{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "PC Monitor by Allain-AFK",
  "version": "0.4.2",
  "identifier": "dev.allain-afk.pc-monitor",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "PC Monitor by Allain-AFK",
        "width": 1100,
        "height": 720,
        "minWidth": 880,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      },
      {
        "label": "overlay",
        "url": "index.html?view=overlay",
        "title": "PC Monitor Overlay",
        "width": 280,
        "height": 180,
        "x": 16,
        "y": 16,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "focusable": false,
        "resizable": false,
        "visible": false,
        "shadow": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "dev-allain-afk",
    "copyright": "Copyright (c) 2026 dev-allain-afk",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/monitor",
      "binaries/sensors"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
